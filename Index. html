// ==================== INITIALIZATION ====================
function init() {
    renderInventory();
    setupEventListeners();
    animateParticles();
}

// ==================== INVENTORY RENDERING ====================
function renderInventory() {
    const grid = document.getElementById('itemsGrid');
    grid.innerHTML = '';
    
    const allItems = [
        ...chemicalsDB.elements,
        ...chemicalsDB.compounds,
        ...chemicalsDB.bio,
        ...chemicalsDB.equipment
    ];
    
    allItems.forEach(item => {
        const card = createItemCard(item);
        grid.appendChild(card);
    });
}

function createItemCard(item) {
    const div = document.createElement('div');
    div.className = 'item-card';
    div.draggable = true;
    div.dataset.id = item.id;
    div.dataset.type = item.type;
    
    const icon = item.icon || getIconForItem(item);
    
    div.innerHTML = `
        <div class="item-icon">${icon}</div>
        <div class="item-name">${item.name}</div>
        <div class="item-formula">${item.formula || ''}</div>
        <div class="item-props">
            <span class="prop-badge">${item.state || item.type}</span>
            <span class="prop-badge">${item.mass || ''}g</span>
        </div>
    `;
    
    div.addEventListener('dragstart', handleDragStart);
    div.addEventListener('dragend', handleDragEnd);
    
    return div;
}

function getIconForItem(item) {
    const icons = {
        element: '⚛️',
        compound: '🧪',
        bio: '🧬',
        equipment: '🔬'
    };
    return icons[item.type] || '⚗️';
}

// ==================== DRAG & DROP ====================
function handleDragStart(e) {
    e.target.classList.add('dragging');
    e.dataTransfer.setData('text/plain', e.target.dataset.id);
}

function handleDragEnd(e) {
    e.target.classList.remove('dragging');
}

function allowDrop(e) {
    e.preventDefault();
}

function drop(e) {
    e.preventDefault();
    const id = e.dataTransfer.getData('text/plain');
    const item = findItemById(id);
    
    if (item) {
        addToWorkspace(item, e.clientX, e.clientY);
    }
}

function findItemById(id) {
    const allItems = [
        ...chemicalsDB.elements,
        ...chemicalsDB.compounds,
        ...chemicalsDB.bio,
        ...chemicalsDB.equipment
    ];
    return allItems.find(i => i.id === id);
}

// ==================== WORKSPACE MANAGEMENT ====================
function addToWorkspace(item, x, y) {
    const workspace = document.getElementById('workspace');
    const el = document.createElement('div');
    el.className = 'dropped-item equipment-container';
    el.style.left = (x - workspace.offsetLeft) + 'px';
    el.style.top = (y - workspace.offsetTop) + 'px';
    el.dataset.itemId = item.id;
    
    const icon = item.icon || getIconForItem(item);
    
    el.innerHTML = `
        <div class="equipment-icon">${icon}</div>
        <div class="equipment-label">${item.name}</div>
        <div class="contents"></div>
    `;
    
    el.addEventListener('click', () => selectItem(el, item));
    el.addEventListener('contextmenu', showContextMenu);
    
    workspace.appendChild(el);
    gameState.workspace.push({element: el, data: item});
    
    showNotification(`${item.name} اضافه شد`);
}

function selectItem(el, item) {
    document.querySelectorAll('.dropped-item').forEach(i => i.classList.remove('selected'));
    el.classList.add('selected');
    gameState.selectedItem = {element: el, data: item};
    updateProperties(item);
}

function updateProperties(item) {
    document.getElementById('selectedItemName').textContent = item.name;
    document.getElementById('selectedMass').textContent = item.mass ? item.mass + ' g/mol' : '-';
    document.getElementById('selectedTemp').textContent = gameState.conditions.temperature + '°C';
    document.getElementById('selectedState').textContent = item.state || 'نامشخص';
}

// ==================== CONDITIONS CONTROL ====================
function updateCondition(type, value) {
    gameState.conditions[type] = parseFloat(value);
    document.getElementById(type + 'Value').textContent = value;
    
    if (type === 'temp') {
        document.getElementById('tempValue').textContent = value + '°C';
    } else if (type === 'pressure') {
        document.getElementById('pressureValue').textContent = value + ' atm';
    } else if (type === 'ph') {
        document.getElementById('phValue').textContent = value;
    }
}

// ==================== REACTION SYSTEM ====================
function checkReactions() {
    const workspaceItems = gameState.workspace.map(w => w.data.id);
    
    reactionsDB.forEach(reaction => {
        const hasAllInputs = reaction.inputs.every(input => 
            workspaceItems.includes(input) || 
            (input === 'light' && gameState.conditions.light) ||
            (input === 'electricity' && gameState.conditions.electricity)
        );
        
        if (hasAllInputs && checkConditions(reaction.conditions)) {
            executeReaction(reaction);
        }
    });
}

function checkConditions(conditions) {
    if (conditions.temp && Math.abs(gameState.conditions.temperature - conditions.temp) > 50) {
        return false;
    }
    if (conditions.pressure && Math.abs(gameState.conditions.pressure - conditions.pressure) > 10) {
        return false;
    }
    return true;
}

function executeReaction(reaction) {
    // Check if already executed
    if (gameState.reactions.find(r => r.id === reaction.id)) return;
    
    gameState.reactions.push(reaction);
    
    // Add outputs to workspace
    reaction.outputs.forEach(outputId => {
        const item = findItemById(outputId);
        if (item) {
            addToWorkspace(item, 
                Math.random() * 400 + 100, 
                Math.random() * 300 + 100
            );
        }
    });
    
    // Log reaction
    logReaction(reaction);
    
    // Visual effect
    createExplosion();
    
    showNotification(`واکنش جدید: ${reaction.name}`);
}

function logReaction(reaction) {
    const list = document.getElementById('reactionsList');
    const div = document.createElement('div');
    div.className = 'reaction-item';
    div.innerHTML = `
        <div class="reaction-equation">${reaction.equation}</div>
        <div class="reaction-desc">${reaction.description}</div>
    `;
    list.insertBefore(div, list.firstChild);
}

// ==================== ACTIONS ====================
function analyzeMixture() {
    checkReactions();
    showNotification('آنالیز کامل شد');
}

function heatMixture() {
    gameState.conditions.temperature += 50;
    document.getElementById('temperature').value = gameState.conditions.temperature;
    updateCondition('temp', gameState.conditions.temperature);
    checkReactions();
    showNotification('دمای محیط افزایش یافت');
}

function coolMixture() {
    gameState.conditions.temperature -= 50;
    document.getElementById('temperature').value = gameState.conditions.temperature;
    updateCondition('temp', gameState.conditions.temperature);
    checkReactions();
    showNotification('دمای محیط کاهش یافت');
}

function clearWorkspace() {
    document.getElementById('workspace').innerHTML = '';
    gameState.workspace = [];
    gameState.reactions = [];
    showNotification('میز کار پاک شد');
}

// ==================== CONTEXT MENU ====================
function showContextMenu(e) {
    e.preventDefault();
    const menu = document.getElementById('contextMenu');
    menu.style.display = 'block';
    menu.style.left = e.pageX + 'px';
    menu.style.top = e.pageY + 'px';
}

function contextAction(action) {
    const menu = document.getElementById('contextMenu');
    menu.style.display = 'none';
    
    if (!gameState.selectedItem) return;
    
    const actions = {
        'measure': () => showNotification('در حال اندازه‌گیری...'),
        'pour': () => showNotification('در حال ریختن...'),
        'heat': () => heatMixture(),
        'cool': () => coolMixture(),
        'stir': () => showNotification('در حال هم زدن...'),
        'filter': () => showNotification('در حال صاف کردن...'),
        'electrolyze': () => { gameState.conditions.electricity = true; checkReactions(); },
        'centrifuge': () => showNotification('در حال سانتریفیوژ...'),
        'dispose': () => {
            gameState.selectedItem.element.remove();
            gameState.workspace = gameState.workspace.filter(w => w !== gameState.selectedItem);
            showNotification('حذف شد');
        }
    };
    
    if (actions[action]) actions[action]();
}

// ==================== UI HELPERS ====================
function showNotification(text) {
    const notif = document.getElementById('notification');
    notif.textContent = text;
    notif.classList.add('show');
    setTimeout(() => notif.classList.remove('show'), 3000);
}

function switchTab(tab) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    // Filter items based on tab
    renderInventory();
}

function filterCategory(category) {
    document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');
    // Filter items
    renderInventory();
}

function searchItems() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    const cards = document.querySelectorAll('.item-card');
    
    cards.forEach(card => {
        const name = card.querySelector('.item-name').textContent.toLowerCase();
        const formula = card.querySelector('.item-formula').textContent.toLowerCase();
        
        if (name.includes(query) || formula.includes(query)) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

function closeModal() {
    document.getElementById('analysisModal').classList.remove('active');
}

function deselectAll(e) {
    if (e.target.id === 'workspace' || e.target.id === 'labTable') {
        document.querySelectorAll('.dropped-item').forEach(i => i.classList.remove('selected'));
        gameState.selectedItem = null;
    }
}

// ==================== VISUAL EFFECTS ====================
function animateParticles() {
    const canvas = document.getElementById('particleCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    
    const particles = [];
    
    for (let i = 0; i < 50; i++) {
        particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            size: Math.random() * 3 + 1
        });
    }
    
    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        particles.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;
            
            if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
            if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
            
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(99, 102, 241, 0.3)';
            ctx.fill();
        });
        
        requestAnimationFrame(animate);
    }
    
    animate();
}

function createExplosion() {
    // Create visual explosion effect
    const workspace = document.getElementById('workspace');
    const explosion = document.createElement('div');
    explosion.style.cssText = `
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100px;
        height: 100px;
        background: radial-gradient(circle, rgba(236, 72, 153, 0.8), transparent);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        animation: explode 0.5s ease-out forwards;
        pointer-events: none;
    `;
    
    const style = document.createElement('style');
    style.textContent = `
        @keyframes explode {
            0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }
            100% { transform: translate(-50%, -50%) scale(3); opacity: 0; }
        }
    `;
    document.head.appendChild(style);
    
    workspace.appendChild(explosion);
    setTimeout(() => explosion.remove(), 500);
}

// ==================== EVENT LISTENERS ====================
function setupEventListeners() {
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.context-menu')) {
            document.getElementById('contextMenu').style.display = 'none';
        }
    });
    
    window.addEventListener('resize', () => {
        const canvas = document.getElementById('particleCanvas');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    });
}

