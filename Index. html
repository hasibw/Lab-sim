<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>آزمایشگاه علمی پیشرفته | Advanced Science Lab</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;700;900&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary: #6366f1;
            --secondary: #ec4899;
            --accent: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --dark: #1e293b;
            --light: #f8fafc;
        }
        
        body {
            font-family: 'Vazirmatn', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: var(--light);
            overflow: hidden;
            height: 100vh;
        }
        
        .app-container {
            display: grid;
            grid-template-columns: 280px 1fr 320px;
            height: 100vh;
            gap: 2px;
            background: #0f172a;
        }
        
        /* Sidebar - Inventory */
        .sidebar {
            background: rgba(30, 41, 59, 0.95);
            backdrop-filter: blur(20px);
            border-left: 1px solid rgba(255,255,255,0.1);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        
        .panel-header {
            padding: 20px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            font-weight: 900;
            font-size: 1.3em;
            text-align: center;
            border-bottom: 2px solid rgba(255,255,255,0.2);
        }
        
        .search-box {
            padding: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .search-box input {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 12px;
            background: rgba(15, 23, 42, 0.8);
            color: white;
            font-family: inherit;
            font-size: 0.95em;
        }
        
        .categories {
            display: flex;
            gap: 5px;
            padding: 10px;
            overflow-x: auto;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .category-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 20px;
            background: rgba(99, 102, 241, 0.2);
            color: white;
            font-family: inherit;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.3s;
            font-size: 0.85em;
        }
        
        .category-btn:hover, .category-btn.active {
            background: var(--primary);
            transform: scale(1.05);
        }
        
        .items-grid {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        
        .item-card {
            background: rgba(255,255,255,0.05);
            border: 2px solid transparent;
            border-radius: 16px;
            padding: 15px;
            cursor: grab;
            transition: all 0.3s;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .item-card:hover {
            border-color: var(--primary);
            transform: translateY(-3px);
            background: rgba(99, 102, 241, 0.1);
        }
        
        .item-card.dragging {
            opacity: 0.5;
            cursor: grabbing;
        }
        
        .item-icon {
            font-size: 2.5em;
            margin-bottom: 8px;
        }
        
        .item-name {
            font-weight: 700;
            font-size: 0.9em;
            margin-bottom: 4px;
        }
        
        .item-formula {
            font-size: 0.75em;
            opacity: 0.7;
            font-family: monospace;
        }
        
        .item-props {
            font-size: 0.7em;
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-around;
        }
        
        .prop-badge {
            background: rgba(255,255,255,0.1);
            padding: 2px 6px;
            border-radius: 4px;
        }
        
        /* Main Lab Area */
        .main-area {
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
            position: relative;
            overflow: hidden;
        }
        
        .lab-table {
            width: 100%;
            height: 100%;
            position: relative;
            background: 
                linear-gradient(45deg, transparent 48%, rgba(255,255,255,0.02) 50%, transparent 52%),
                linear-gradient(-45deg, transparent 48%, rgba(255,255,255,0.02) 50%, transparent 52%);
            background-size: 60px 60px;
        }
        
        .workspace {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%;
            height: 90%;
            border: 3px dashed rgba(99, 102, 241, 0.3);
            border-radius: 30px;
            background: rgba(15, 23, 42, 0.3);
        }
        
        .dropped-item {
            position: absolute;
            cursor: move;
            user-select: none;
            transition: transform 0.1s;
            z-index: 10;
        }
        
        .dropped-item:hover {
            z-index: 100;
        }
        
        .dropped-item.selected {
            filter: drop-shadow(0 0 15px var(--primary));
            z-index: 50;
        }
        
        .equipment-container {
            width: 120px;
            height: 120px;
            background: rgba(255,255,255,0.1);
            border: 3px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            backdrop-filter: blur(10px);
        }
        
        .equipment-container.beaker {
            border-color: var(--accent);
            background: rgba(16, 185, 129, 0.1);
        }
        
        .equipment-container.flask {
            border-color: var(--secondary);
            background: rgba(236, 72, 153, 0.1);
        }
        
        .equipment-icon {
            font-size: 3em;
        }
        
        .equipment-label {
            font-size: 0.8em;
            margin-top: 5px;
            font-weight: 700;
        }
        
        .contents {
            position: absolute;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80%;
            max-height: 60px;
            overflow: hidden;
            font-size: 0.7em;
            text-align: center;
        }
        
        .substance-particle {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin: 1px;
            animation: float 3s ease-in-out infinite;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }
        
        .temperature-indicator {
            position: absolute;
            top: -30px;
            right: 0;
            background: var(--danger);
            padding: 5px 10px;
            border-radius: 10px;
            font-size: 0.8em;
            font-weight: 700;
        }
        
        /* Right Panel - Properties & Reactions */
        .right-panel {
            background: rgba(30, 41, 59, 0.95);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255,255,255,0.1);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        
        .properties-section {
            padding: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .section-title {
            font-weight: 700;
            margin-bottom: 15px;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .property-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        
        .property-label {
            opacity: 0.7;
            font-size: 0.9em;
        }
        
        .property-value {
            font-weight: 700;
            font-family: monospace;
        }
        
        .slider-control {
            margin: 15px 0;
        }
        
        .slider-control label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.9em;
        }
        
        .slider {
            width: 100%;
            height: 8px;
            border-radius: 4px;
            background: rgba(255,255,255,0.1);
            outline: none;
            -webkit-appearance: none;
        }
        
        .slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--primary);
            cursor: pointer;
        }
        
        .reaction-log {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            background: rgba(15, 23, 42, 0.5);
        }
        
        .reaction-item {
            background: rgba(99, 102, 241, 0.1);
            border-right: 4px solid var(--primary);
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 12px;
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from { transform: translateX(20px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        .reaction-equation {
            font-family: monospace;
            font-size: 1.1em;
            margin-bottom: 8px;
            color: var(--accent);
        }
        
        .reaction-desc {
            font-size: 0.85em;
            opacity: 0.8;
            line-height: 1.6;
        }
        
        .action-buttons {
            padding: 20px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
        
        .action-btn {
            padding: 15px;
            border: none;
            border-radius: 12px;
            font-family: inherit;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.95em;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
        }
        
        .btn-danger {
            background: var(--danger);
            color: white;
        }
        
        .btn-warning {
            background: var(--warning);
            color: black;
        }
        
        .btn-accent {
            background: var(--accent);
            color: white;
        }
        
        .action-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        
        /* Context Menu */
        .context-menu {
            position: absolute;
            background: rgba(30, 41, 59, 0.98);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 10px 0;
            min-width: 200px;
            z-index: 1000;
            display: none;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }
        
        .context-item {
            padding: 12px 20px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .context-item:hover {
            background: rgba(99, 102, 241, 0.2);
        }
        
        /* Modals */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }
        
        .modal.active {
            display: flex;
        }
        
        .modal-content {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            border: 2px solid var(--primary);
            border-radius: 30px;
            padding: 40px;
            max-width: 800px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            position: relative;
        }
        
        .modal-close {
            position: absolute;
            top: 20px;
            left: 20px;
            font-size: 2em;
            cursor: pointer;
            opacity: 0.7;
            transition: opacity 0.3s;
        }
        
        .modal-close:hover {
            opacity: 1;
        }
        
        .crafting-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin: 30px 0;
        }
        
        .craft-slot {
            aspect-ratio: 1;
            background: rgba(255,255,255,0.05);
            border: 3px dashed rgba(255,255,255,0.2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2em;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .craft-slot:hover {
            border-color: var(--primary);
            background: rgba(99, 102, 241, 0.1);
        }
        
        .craft-slot.filled {
            border-style: solid;
            border-color: var(--accent);
            background: rgba(16, 185, 129, 0.1);
        }
        
        /* Particles Canvas */
        #particleCanvas {
            position: absolute;
            top: 0;
            left: 0;
            pointer-events: none;
            z-index: 5;
        }
        
        /* Tabs */
        .tabs {
            display: flex;
            gap: 5px;
            padding: 10px;
            background: rgba(15, 23, 42, 0.5);
        }
        
        .tab {
            padding: 10px 20px;
            border: none;
            background: transparent;
            color: white;
            font-family: inherit;
            cursor: pointer;
            border-radius: 10px;
            transition: all 0.3s;
            font-size: 0.9em;
        }
        
        .tab:hover, .tab.active {
            background: rgba(99, 102, 241, 0.3);
        }
        
        /* Notification */
        .notification {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(-100px);
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            padding: 20px 40px;
            border-radius: 50px;
            font-weight: 700;
            z-index: 3000;
            transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        
        .notification.show {
            transform: translateX(-50%) translateY(0);
        }
        
        /* Responsive */
        @media (max-width: 1200px) {
            .app-container {
                grid-template-columns: 240px 1fr 280px;
            }
        }
        
        @media (max-width: 900px) {
            .app-container {
                grid-template-columns: 1fr;
                grid-template-rows: auto 1fr auto;
            }
            .sidebar, .right-panel {
                height: 300px;
            }
        }
    </style>
</head>
